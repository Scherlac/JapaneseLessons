# Copy this file to .env and fill in the values for your local environment.
# Do not commit your .env file if it contains secrets.

# LLM / model server settings
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3-14b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384
LLM_REQUEST_TIMEOUT=120
LLM_NO_THINK=true
# Optional advanced reasoning mode: none, low, medium, high, xhigh
LLM_REASONING_EFFORT=none
LLM_DEBUG=false

# RCM store path used by lesson generation and the rcm CLI group.
# If set, this is used as the default for --rcm and --rcm-path options.
JLESSON_RCM_PATH=/path/to/.jlesson/rcm
